generator client {
  provider   = "prisma-client-js"
  output     = "../src/generated/prisma"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String    @id @default(uuid())
  createdAt DateTime  @default(now())
  clerkId   String    @unique
  projects  Project[]
}

model Project {
  id          String    @id @default(cuid())
  name        String
  description String?
  type        String?
  techStack   String[]
  status      String?
  startDate   DateTime?
  targetDate  DateTime?
  owner       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  userId      String
  phases      Phase[]
  user        User      @relation(fields: [userId], references: [id])
}

model Phase {
  id          String      @id @default(cuid())
  name        String
  description String?
  order       Int
  status      String?
  progress    Int         @default(0)
  projectId   String
  milestones  Milestone[]
  project     Project     @relation(fields: [projectId], references: [id])
}

model Milestone {
  id          String  @id @default(cuid())
  title       String
  description String?
  progress    Int     @default(0)
  phaseId     String
  phase       Phase   @relation(fields: [phaseId], references: [id])
  tasks       Task[]
}

model Task {
  id          String    @id @default(cuid())
  title       String
  type        String?
  purpose     String?
  commands    String[]
  done        Boolean   @default(false)
  milestoneId String
  milestone   Milestone @relation(fields: [milestoneId], references: [id])
}

model Test {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
}
