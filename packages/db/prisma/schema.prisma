generator client {
  provider = "prisma-client"
  output   = "../src/generated"
}

datasource db {
  provider = "postgresql"
}
model Milestone {
  id          String  @id @default(uuid())
  title       String
  description String?
  progress    Int     @default(0)

  phaseId String
  phase   Phase @relation(fields: [phaseId], references: [id])

  tasks Task[]
}

model Phase {
  id          String      @id @default(uuid())
  name        String
  description String?
  order       Int
  status      String?
  progress    Int         @default(0)

  projectId String
  project   Project @relation(fields: [projectId], references: [id])

  milestones Milestone[]
}

model Project {
  id          String    @id @default(uuid())
  name        String
  description String?
  type        String?
  techStack   String[]
  status      String?
  startDate   DateTime?
  targetDate  DateTime?
  owner       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @default(now())

  userId String
  user   User @relation(fields: [userId], references: [id])

  phases Phase[]
}

model Task {
  id          String    @id @default(uuid())
  title       String
  type        String?
  purpose     String?
  commands    String[]
  done        Boolean   @default(false)

  milestoneId String
  milestone   Milestone @relation(fields: [milestoneId], references: [id])
}

model User {
  id        String    @id
  createdAt DateTime  @default(now())
  clerkId   String    @unique

  projects Project[]
}